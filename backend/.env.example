PORT=5000
CLIENT_URL=https://your-app.onrender.com

NODE_ENV=production

# MongoDB Atlas — get from cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nextowner?retryWrites=true&w=majority

# JWT — any random long string (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random

# Cloudinary — get from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth — get from console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Email (Gmail SMTP) ──────────────────────────────────────
# REQUIRED for: OTP verification, password reset, support ack
#
# Step-by-step setup for Gmail:
#  1. Enable 2-Step Verification on your Google account
#  2. Go to myaccount.google.com → Security → App passwords
#  3. Generate an App Password (choose "Mail" + "Other")
#  4. Paste the 16-char App Password as MAIL_PASS below
#  5. DO NOT use your regular Gmail password — it will not work
#
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=nishchalkc370@gmail.com
MAIL_PASS=your_16_char_gmail_app_password_here
SUPPORT_EMAIL=nishchalkc370@gmail.com
SUPPORT_NAME=NextOwner Support

# Admin dashboard login
ADMIN_EMAIL=admin@nextowner.in
ADMIN_PASSWORD=your_admin_password_here
