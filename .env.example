# ── Frontend Environment Variables ──
# Copy this file to .env and fill in your values

# Backend API URL (change to your deployed backend URL in production)
VITE_API_BASE=http://localhost:5000/api

# Google OAuth Client ID
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add Authorized JS origins: http://localhost:5173
# 5. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID=682068990001-bp9emp9qeonc4nbr15etq2m86r1sok8c.apps.googleusercontent.com
